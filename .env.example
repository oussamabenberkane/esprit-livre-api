# ===========================================
# Esprit Livre Production Environment
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Domain Configuration
# ===========================================
DOMAIN=espritlivre.com
VERSION=latest

# ===========================================
# Database Configuration
# ===========================================
DB_USER=espritlivre
DB_PASSWORD=your_secure_database_password_here
DB_NAME=espritlivre

# Keycloak database (can use same credentials)
KC_DB_NAME=keycloak

# ===========================================
# Keycloak Configuration
# ===========================================
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=your_secure_keycloak_admin_password_here

# ===========================================
# OAuth2 Configuration
# ===========================================
# These must match your Keycloak realm configuration
OAUTH_CLIENT_ID=web_app
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# ===========================================
# Application Configuration
# ===========================================
ADMIN_EMAIL=admin@espritlivre.com

# ===========================================
# Shipping Providers
# ===========================================
# Yalidine (optional)
YALIDINE_ENABLED=false
YALIDINE_API_ID=
YALIDINE_API_TOKEN=
YALIDINE_WEBHOOK_SECRET=

# ZR Express
ZR_EXPRESS_ENABLED=true
ZR_EXPRESS_TENANT_ID=your_zr_tenant_id
ZR_EXPRESS_API_KEY=your_zr_api_key

# ===========================================
# Email Configuration (SMTP)
# ===========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password

# ===========================================
# Meta Pixel / Conversions API
# ===========================================
META_ENABLED=false
META_PIXEL_ID=1000542266262130
META_ACCESS_TOKEN=your-capi-access-token-here

# ===========================================
# Frontend Build Configuration
# ===========================================
VITE_API_URL=https://api.espritlivre.com
VITE_AUTH_URL=https://auth.espritlivre.com

# ===========================================
# WhatsApp Agent (whatsapp-agent service)
# ===========================================
# WhatsApp Cloud API (Meta) — System User token + phone number ID
WHATSAPP_TOKEN=your-whatsapp-system-user-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# Webhook verify token — must match the value set in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
GRAPH_API_VERSION=v23.0
# Mistral LLM — console.mistral.ai (mistral-small-latest = fast/cheap)
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest
# Messenger + Instagram (optional — leave empty to disable those channels)
PAGE_ACCESS_TOKEN=
